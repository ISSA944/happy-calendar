generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// CORE: users + auth credentials
// ─────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?   @map("password_hash")
  otpHash          String?   @map("otp_hash")
  otpExpiresAt     DateTime? @map("otp_expires_at")
  refreshTokenHash String?   @map("refresh_token_hash")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  profile       Profile?
  prefs         Prefs?
  dailyFeeds    DailyFeed[]
  bookmarks     Bookmark[]
  moodLogs      MoodLog[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// PROFILE: кто такой юзер (астрология + текущее настроение)
// ─────────────────────────────────────────────────────────────
model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthdate   String?
  zodiacSign  String?  @map("zodiac_sign")
  gender      String?
  avatarUrl   String?  @map("avatar_url")
  currentMood String   @default("Нормально") @map("current_mood")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("profile")
}

// ─────────────────────────────────────────────────────────────
// PREFS: настройки + устройства + согласие ПД
// ─────────────────────────────────────────────────────────────
model Prefs {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushTime         String   @default("09:00") @map("push_time")
  fcmTokens        String[] @default([]) @map("fcm_tokens")
  horoscopeEnabled Boolean  @default(true) @map("horoscope_enabled")
  holidaysEnabled  Boolean  @default(false) @map("holidays_enabled")
  supportEnabled   Boolean  @default(true) @map("support_enabled")
  consentPd        Boolean  @default(false) @map("consent_pd")
  timezone         String   @default("Europe/Moscow")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("prefs")
}

// ─────────────────────────────────────────────────────────────
// SHARED REF TABLES — расшариваются между юзерами
// Экономия LLM: 1 гороскоп на (date, zodiacSign) на всех
// ─────────────────────────────────────────────────────────────
model Horoscope {
  id         String   @id @default(uuid())
  date       String
  zodiacSign String   @map("zodiac_sign")
  main       String
  detailed   String?
  advice     String
  moon       String
  aspect     String
  createdAt  DateTime @default(now()) @map("created_at")

  dailyFeeds DailyFeed[]

  @@unique([date, zodiacSign])
  @@index([date])
  @@map("horoscopes")
}

model Holiday {
  id          String   @id @default(uuid())
  date        String   @unique
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  dailyFeeds DailyFeed[]

  @@map("holidays")
}

model SupportPhrase {
  id        String   @id @default(uuid())
  mood      String
  text      String
  usedCount Int      @default(0) @map("used_count")
  createdAt DateTime @default(now()) @map("created_at")

  dailyFeeds DailyFeed[]

  @@index([mood])
  @@map("support_phrases")
}

model Prompt {
  id        String   @id @default(uuid())
  type      String   @unique
  template  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("prompts")
}

// ─────────────────────────────────────────────────────────────
// DAILY FEED: join-таблица user↔ref-content на конкретный день
// ─────────────────────────────────────────────────────────────
model DailyFeed {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            String
  horoscopeId     String?        @map("horoscope_id")
  horoscope       Horoscope?     @relation(fields: [horoscopeId], references: [id])
  supportPhraseId String?        @map("support_phrase_id")
  supportPhrase   SupportPhrase? @relation(fields: [supportPhraseId], references: [id])
  holidayId       String?        @map("holiday_id")
  holiday         Holiday?       @relation(fields: [holidayId], references: [id])
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("daily_feed")
}

// ─────────────────────────────────────────────────────────────
// BOOKMARKS: snapshot на момент сохранения (immutable)
// ─────────────────────────────────────────────────────────────
model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("bookmarks")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────
model MoodLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      String
  changedAt DateTime @default(now()) @map("changed_at")

  @@index([userId])
  @@map("mood_logs")
}

model Notification {
  id     String   @id @default(uuid())
  userId String   @map("user_id")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAt DateTime @default(now()) @map("sent_at")
  type   String
  status String

  @@index([userId])
  @@map("notifications")
}
