# Frontend environment — Firebase Cloud Messaging (client SDK)
# Get these from Firebase Console → Project Settings → General → Your apps → Web SDK config.
# Copy this file to .env.local and fill in real values.
# VITE_* vars are embedded into the client bundle and are safe to commit as public keys.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=happy-calendar-a5e69.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=happy-calendar-a5e69
VITE_FIREBASE_STORAGE_BUCKET=happy-calendar-a5e69.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# Optional — override API base URL (defaults to /api via Vite proxy in dev).
# VITE_API_BASE_URL=http://localhost:4000/api
